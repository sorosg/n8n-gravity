# ============================================================
# n8n + Gravity CMS Automatizáció Környezeti Változók
# Másold át ezt a fájlt .env néven, majd töltsd ki az értékeket!
#   cp .env.example .env
# ============================================================

# ----- n8n Alapbeállítások -----
N8N_AUTH_ACTIVE=true
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=CHANGE_THIS_PASSWORD
N8N_HOST=0.0.0.0
N8N_PORT=5678
# Webes felület (nginx) portja – a 80 foglalt, ezért 8080:
WEB_PORT=8080
# Gravity CMS tesztkörnyezet portja:
GRAVITY_PORT=8085
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=  # Generáld: openssl rand -hex 32
N8N_USER_MANAGEMENT_DISABLED=false

# Webhook URL (ha külső hozzáférés kell, pl. ngrok vagy saját domain)
# N8N_WEBHOOK_URL=https://n8n.yourdomain.com

# Végrehajtási logok megőrzése (órában, 168 = 7 nap)
EXECUTIONS_MAX_AGE=168
EXECUTIONS_PRUNE_MAX=50000

# Külső n8n kiegészítők (npm csomagok) engedélyezése
N8N_EXTERNAL_EXTENSIONS=false

# ----- PostgreSQL Adatbázis -----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=n8n
DB_USER=n8n
DB_PASSWORD=CHANGE_DB_PASSWORD
DB_SCHEMA=public

# ----- AI API Kulcsok -----
# DeepSeek API kulcs (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API kulcs (opcionális, fallback-ként)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ----- Qdrant Vektor Adatbázis (opcionális, a "full" vagy "ai" profilhoz) -----
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ----- Ollama Lokális AI (opcionális, a "full" vagy "ai" profilhoz) -----
OLLAMA_PORT=11434

# ----- Portainer CE (opcionális, a "full" vagy "management" profilhoz) -----
PORTAINER_PORT=9443
PORTAINER_AGENT_PORT=9000

# ----- Gravity CMS Specifikus Változók -----
# Ezeket a workflow-k használják, nem maga az n8n
# (n8n-ben credential-ként vagy környezeti változóként kezelve)

# Alapértelmezett nyelv a generált tartalomhoz
GRAVITY_DEFAULT_LANGUAGE=hu

# Kimeneti könyvtár a generált Gravity CMS fájlokhoz
GRAVITY_OUTPUT_DIR=/home/node/.n8n/output/gravity

# Engedélyezni kívánt Gravity CMS sablon típusok (vesszővel elválasztva)
GRAVITY_TEMPLATE_TYPES=landing_page,blog,portfolio,shop,admin